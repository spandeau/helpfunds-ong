{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Auteur"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "name": { "type": "string", "required": true },
    "email": { "type": "email" },
    "bio": { "type": "text" },
    "avatar": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "role": {
      "type": "enumeration",
      "enum": ["super_admin", "gestionnaire", "moderateur", "comptable", "contributeur"],
      "default": "contributeur"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "author"
    },
    "active": { "type": "boolean", "default": true }
  }
}